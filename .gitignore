# .gitignore - entradas uteis para VSCode e arquivos "lixo" comuns
# Ajuste conforme necessario para seu projeto especifico

### Editor/IDE
.vscode/
*.code-workspace
.history/

### macOS
.DS_Store
.AppleDouble
.LSOverride

### Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp.*
.cache/
dist/
build/

### Python
__pycache__/
*.py[cod]
*$py.class
*.so
venv/
env/
ENV/
.env
.env.*
.venv/
.pytest_cache/

### Java / JVM
*.class
target/
build/
.gradle/

### IDEs (IntelliJ, Eclipse, etc.)
.idea/
*.iml
*.ipr
*.iws

### Logs and reports
*.log
coverage/
coverage-report/
*.lcov

### System files
Thumbs.db
ehthumbs.db
Desktop.ini

### Temporary files
*.tmp
*.temp
*~
# npm/yarn lock files are often committed; uncomment if you want to ignore them
# package-lock.json
# yarn.lock

### Environment and secrets
.env.local
.env.*.local
.secret

### Misc
*.swp
*.swo
*.bak
*.orig
