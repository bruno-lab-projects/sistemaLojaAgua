<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.distribuidora.PrimaryController">
   <children>
      <TabPane prefHeight="482.0" prefWidth="376.0" tabClosingPolicy="UNAVAILABLE">
        <tabs>
          <Tab text="Pedidos">
            <content>
              <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0" />
            </content>
          </Tab>
          <Tab text="Clientes">
            <content>
              <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                     <children>
                        <Label layoutX="9.0" layoutY="86.0" text="Telefone" />
                        <Label layoutX="7.0" layoutY="131.0" text="Endereço" />
                        <Label layoutX="9.0" layoutY="41.0" text="Nome" />
                        <TextField fx:id="nomeField" layoutX="81.0" layoutY="37.0" />
                        <TextField fx:id="telefoneField" layoutX="81.0" layoutY="82.0" />
                        <TextField fx:id="enderecoField" layoutX="81.0" layoutY="127.0" />
                        <Button fx:id="salvarButton" layoutX="81.0" layoutY="177.0" mnemonicParsing="false" onAction="#handleSalvarCliente" text="Salvar cliente" />
                        <TableView fx:id="clientesTable" layoutX="9.0" layoutY="210.0" prefHeight="233.0" prefWidth="362.0">
                           <columns>
                              <TableColumn fx:id="colNome" prefWidth="115.0" text="Nome" />
                              <TableColumn fx:id="colTelefone" prefWidth="122.0" text="Telefone" />
                              <TableColumn fx:id="colEndereco" prefWidth="124.0" text="Endereco" />
                           </columns>
                        </TableView>
                     </children>
                  </AnchorPane>
            </content>
          </Tab>
            <Tab text="Dashboard">
               <content>
                  <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0" />
               </content>
            </Tab>
        </tabs>
      </TabPane>
      <Label text="vista suave" />
      <Button fx:id="primaryButton" onAction="#switchToSecondary" text="clica aqui man" />
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
